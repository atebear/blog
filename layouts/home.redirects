{{- /* Single site redirects */ -}}
{{- range .Site.RegularPages -}}
  {{- range .Params.aliases -}}
    {{- /* Optional: Check for whitespace in aliases */ -}}
    {{- if findRE `\s` . -}}
      {{- errorf "One of the front matter aliases in %q contains whitespace" . -}}
    {{- end -}}
    {{- printf "%s %s 301\n" . .RelPermalink -}}
  {{- end -}}
{{- end -}}
